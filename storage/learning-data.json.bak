    {
      "type": "question_cycle",
      "userId": "demo-user",
      "sessionId": "session_2b499e41-dc91-4d89-bf4e-bfa2889e3a3b",
      "topicKey": "h-th-ng-rag",
      "topicLabel": "Hệ thống RAG",
      "question": "RAG là gì",
      "answer": "RAG (Retrieval Augmented Generation) là một kỹ thuật giúp các mô hình ngôn ngữ lớn (LLM) trả lời chính xác hơn bằng cách tìm kiếm thông tin liên quan từ một kho dữ liệu bên ngoài trước khi tạo ra câu trả lời. Điều này giúp LLM có thêm ngữ cảnh và giảm việc đưa ra thông tin sai lệch.",
      "reflectionQuestion": "Làm thế nào RAG giúp giảm “ảo giác” của các mô hình AI?",
      "followUpSuggestions": [
        "Các thành phần chính của hệ thống RAG là gì?",
        "Điểm khác biệt giữa RAG và fine-tuning (tinh chỉnh) LLM là gì?",
        "Embedding được sử dụng trong RAG như thế nào?"
      ],
      "knowledgeGaps": [
        "Mô hình ngôn ngữ lớn (LLM)",
        "Cơ chế truy xuất thông tin"
      ],
      "source": "gemini-api",
      "provider": "gemini",
      "createdAt": "2026-04-17T19:22:05.815Z"
    },
    {
      "type": "reflection",
      "userId": "demo-user",
      "sessionId": "session_2b499e41-dc91-4d89-bf4e-bfa2889e3a3b",
      "topicKey": "h-th-ng-rag",
      "topicLabel": "Hệ thống RAG",
      "understandingStatus": "confused",
      "knowledgeGaps": [
        "Mô hình ngôn ngữ lớn (LLM)",
        "Cơ chế truy xuất thông tin"
      ],
      "clarification": "Chào bạn, có vẻ bạn vẫn còn băn khoăn về RAG, đặc biệt là về 'Mô hình ngôn ngữ lớn' và 'Cơ chế truy xuất thông tin'. Hãy thử hình dung thế này nhé: một 'Mô hình ngôn ngữ lớn' (LLM) giống như một học sinh rất thông minh, nhưng đôi khi vẫn có thể quên hoặc nhầm lẫn thông tin. Còn 'Cơ chế truy xuất thông tin' thì giống như việc học sinh đó biết cách tìm kiếm đúng cuốn sách trong thư viện (kho dữ liệu bên ngoài) để kiểm tra hoặc bổ sung kiến thức trước khi trả lời câu hỏi. RAG chính là sự kết hợp đó: học sinh thông minh dùng thư viện để đưa ra câu trả lời chính xác và đầy đủ nhất.",
      "followUpSuggestions": [
        "RAG khác gì so với việc chỉ dùng LLM đơn thuần?",
        "Lợi ích chính của RAG là gì?",
        "Khi nào thì nên sử dụng hệ thống RAG?"
      ],
      "source": "gemini-api",
      "provider": "gemini",
      "createdAt": "2026-04-17T19:22:18.234Z"
    },
    {
